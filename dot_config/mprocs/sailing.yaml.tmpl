procs:
  sailing-retrieval-proxy:
    cwd: "{{ .chezmoi.homeDir }}/go/projects/woa/pubtool/app/sailing/cmd/sailing_retrieval_proxy"
    shell: go run main.go 2>&1 | tee /tmp/sailingproxy.log
    autostart: true
    env:
      HTTPS_PROXY: "http://localhost:12639"

  tte-agent:
    cwd: {{ .chezmoi.homeDir }}/go/projects/woa/tte_agent
    shell: go run . 2>&1 |tee /tmp/sailingagent.log
    autostart: true
    env:
      HTTPS_PROXY: "http://localhost:12639"

  sailing-verify:
    cwd: {{ .chezmoi.homeDir }}/go/projects/woa/sailing-verify
    shell: make dev 2>&1 |tee /tmp/sailingverify
    autostart: true
    env:
      HTTPS_PROXY: "http://localhost:12639"
  
  ysp-mcp:
    # cmd: ["ysp-mcp"]
    shell: ysp-mcp > /tmp/ysp-media-mcp.log 2>&1
    autostart: false
    env:
      PORT: "9090"
      YSP_LOG_LEVEL: "DEBUG"

  ysp-sports-mcp:
    shell: ysp-sports-mcp > /tmp/ysp-sports-mcp.log 2>&1
    autostart: false
    env:
      PORT: "9091"
      YSP_LOG_LEVEL: "DEBUG"

