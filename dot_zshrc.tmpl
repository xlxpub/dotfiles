# 语言设置
export LANG=zh_CN.UTF-8
export LC_ALL=zh_CN.UTF-8
export EDITOR="nvim"

# iTerm2 窗口标题显示当前目录名
DISABLE_AUTO_TITLE=true
setopt prompt_subst

autoload -Uz add-zsh-hook
_set_iterm_title() {
  # %1~ = 最后一级目录名，在 $HOME 下显示为 ~
  # \e]0; 同时设置窗口标题和 tab/图标名（兼容性最好）
  print -Pn "\e]0;%1~\a"
}
_set_iterm_title_preexec() {
  # 命令执行期间也显示目录名（不随命令名变化）
  print -Pn "\e]0;%1~\a"
}
add-zsh-hook precmd   _set_iterm_title   # 命令结束后（显示提示符前）
add-zsh-hook chpwd    _set_iterm_title   # cd 后立即更新

# 历史记录
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt HIST_IGNORE_DUPS       # 不记录连续重复命令
setopt HIST_FIND_NO_DUPS      # 搜索时跳过重复条目
setopt SHARE_HISTORY          # 多 tab/窗口实时共享历史（执行后立即同步）
setopt HIST_IGNORE_SPACE      # 命令前加空格则不记录到历史

export FUNCNEST=100

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  PATH 与开发环境
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
{{ if eq .chezmoi.arch "arm64" -}}
# homebrew（M 芯片）
eval "$(/opt/homebrew/bin/brew shellenv)"
{{ else -}}
# homebrew（Intel）
eval "$(/usr/local/bin/brew shellenv)"
{{ end }}
# GNU 工具（覆盖 macOS 自带的 BSD 版本）
path=(
  #/opt/homebrew/opt/findutils/libexec/gnubin
  # /opt/homebrew/opt/gnu-sed/libexec/gnubin
  #/opt/homebrew/opt/grep/libexec/gnubin
  #/opt/homebrew/opt/coreutils/libexec/gnubin
  $path
)

# 用户本地 bin
path=($HOME/.local/bin $HOME/bin $path)

# Go
{{ if eq .chezmoi.arch "arm64" -}}
export GOROOT="/usr/local/go"
{{ else -}}
export GOROOT="$HOME/go/pkg/mod/golang.org/toolchain@v0.0.1-go1.25.5.darwin-amd64"
{{ end -}}
export GOPATH="$HOME/go"
export GOMODCACHE="$GOPATH/pkg/mod"
export GOCACHE="$HOME/Library/Caches/go-build"
path=($GOROOT/bin $GOPATH/bin $path)

# pyenv
path=($HOME/.pyenv/shims $path)

# 其他工具
path=(
  $HOME/.codebuddy/bin
  /opt/podman/bin
{{ if eq .chezmoi.arch "arm64" -}}
  /opt/homebrew/opt/mysql@8.0/bin
{{ else -}}
  /usr/local/opt/mysql@8.0/bin
{{ end -}}
  $path
)

# JDK
{{ if eq .chezmoi.arch "arm64" -}}
# export JAVA_HOME="/opt/homebrew/opt/openjdk@8"
{{ else -}}
# export JAVA_HOME="/usr/local/opt/openjdk@8"
{{ end -}}
# path=($JAVA_HOME/bin $path)

# PATH 去重 + 剔除不存在目录（zsh 内置：-U 数组去重，(N-/) 只保留存在的目录）
typeset -U path
path=($^path(N-/))
export PATH

# Android SDK / NDK
# export ANDROID_NDK_HOME="$HOME/Library/Android/sdk"



# zoxide 初始化（快速目录导航）
eval "$(zoxide init zsh)"

# Starship 提示符初始化
eval "$(starship init zsh)"

# zsh-completions 补全增强（必须在 compinit 之前加入 fpath）
if [[ -d ~/.local/share/zsh/plugins/zsh-completions/src ]]; then
  fpath=(~/.local/share/zsh/plugins/zsh-completions/src $fpath)
fi

# 加载补全系统（必须在所有插件加载之前）
# 优化：使用缓存策略，24小时内使用缓存（快 10 倍）
autoload -Uz compinit
if [[ -n ${ZDOTDIR}/.zcompdump(#qNmh+24) ]]; then
  compinit
else
  compinit -C
fi

# 补全配置：
# 1. 不区分大小写
# 2. 支持下划线、点、横线分隔符跳过补全（hello_2026.txt 中输入 2026 可以补全）
zstyle ':completion:*' matcher-list \
  'm:{a-zA-Z}={A-Za-z}' \
  'r:|[._-]=* r:|=*' \
  'l:|=* r:|=*'
zstyle ':completion:*' move-cursor end  # 补全后光标自动移到行尾

# zsh-autosuggestions 自动建议（nvim 内置终端中禁用，避免 execute:xxx 乱码）
if [[ -f ~/.local/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh ]]; then
  if [[ -z "$NVIM" ]]; then
    source ~/.local/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
  fi
fi

# zsh-syntax-highlighting 语法高亮
if [[ -f ~/.local/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]]; then
  source ~/.local/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
fi

# git 插件（别名和函数）
if [[ -f ~/.local/share/zsh/plugins/git/git.plugin.zsh ]]; then
  source ~/.local/share/zsh/plugins/git/git.plugin.zsh
fi

# fzf 模糊搜索
if [[ -f ~/.fzf.zsh ]]; then
  source ~/.fzf.zsh
fi

# fzf 配置选项
export FZF_DEFAULT_OPTS="
--height 40%
--layout reverse
--border
--preview '
if [ -d {} ]; then
  tree -C {} | head -100
else
  bat --color=always --style=numbers {}
fi
'
--preview-window right:60%:wrap
--bind '?:toggle-preview'
"
export FZF_CTRL_R_OPTS="--preview 'echo {}' --preview-window down:3:hidden:wrap --bind '?:toggle-preview'"

# 别名
alias cc="claude-internal"
alias claude="claude-internal"
alias zi="zoxide query --interactive"
alias v="nvim"
alias vi="nvim"
alias vim="nvim"
alias lg="lazygit"
alias read_union='python $HOME/go/projects/woa/tools/py/readunion.py'
alias ls="lsd"
alias ll="lsd -l"
alias la="lsd -la"
alias lt="lsd --tree"

# vim keybind 设置
bindkey -v                                    # 启用 Vi 模式
export KEYTIMEOUT=1                           # 减少 Esc 延迟

# 删除键修复
bindkey "^?" backward-delete-char             # Backspace 键
bindkey "^H" backward-delete-char             # Ctrl+H 删除前一个字符
bindkey "^[[3~" delete-char                   # Delete 键

# 常用导航键
bindkey "^[[H" beginning-of-line              # Home 键 - 行首
bindkey "^[[F" end-of-line                    # End 键 - 行尾

# 方向键导航（按前缀搜索历史：输入 ls 再按上箭头，只显示 ls 开头的命令）
bindkey "^[[A" history-beginning-search-backward  # 上方向键 - 按前缀向前搜索历史
bindkey "^[[B" history-beginning-search-forward   # 下方向键 - 按前缀向后搜索历史
bindkey "^[[C" forward-char                   # 右方向键 - 光标向右
bindkey "^[[D" backward-char                  # 左方向键 - 光标向左

# Vi 模式下的快捷键
bindkey -M viins '^A' beginning-of-line       # Ctrl+A - 插入模式下跳到行首
bindkey -M viins '^E' end-of-line             # Ctrl+E - 插入模式下跳到行尾
bindkey -M viins "jj" vi-cmd-mode             # jj - 快速从插入模式进入命令模式

if [[ -f ~/.zshrc.local ]]; then
  source ~/.zshrc.local
fi

alias start_sailing_proxy="sh $HOME/go/projects/woa/pubtool/app/sailing/cmd/sailing_retrieval_proxy/start_go.sh"

[[ -f $HOME/.env ]] && source $HOME/.env

# !! 必须在 starship init 之后注册，否则会被 Starship 的 preexec 覆盖 !!
add-zsh-hook preexec _set_iterm_title_preexec
